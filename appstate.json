const axios = require("axios");
const fs = require("fs-extra");
const path = require("path");

module.exports = {
  config: {
    name: "lovevid",
    version: "4.0",
    author: "Hasan + Nazim Fix",
    role: 0,
    countDown: 5,
    shortDescription: "Random Love Video",
    longDescription: "Send random romantic video",
    category: "randomvideo",
    guide: {
      en: "{pn}"
    }
  },

  onStart: async function ({ api, event, message }) {
    try {

      const cachePath = path.join(__dirname, "cache");
      const filePath = path.join(cachePath, "lovevideo.mp4");

      if (!fs.existsSync(cachePath)) {
        fs.mkdirSync(cachePath);
      }

      const loading = await message.reply("💞 | Loading Romantic Video...");

      const res = await axios.get("https://a6-video-api.onrender.com/video/love");

      if (!res.data) {
        return api.sendMessage("❌ | Love video পাওয়া যায়নি!", event.threadID, event.messageID);
      }

      const videoUrl = res.data.data || res.data.url || res.data.video;

      if (!videoUrl) {
        return api.sendMessage("❌ | API থেকে video link পাওয়া যায়নি!", event.threadID, event.messageID);
      }

      const video = await axios({
        url: videoUrl,
        method: "GET",
        responseType: "stream",
        headers: { "User-Agent": "Mozilla/5.0" }
      });

      const writer = fs.createWriteStream(filePath);
      video.data.pipe(writer);

      writer.on("finish", () => {

        api.unsendMessage(loading.messageID);

        api.sendMessage(
          {
            body: "💖 𝗥𝗔𝗡𝗗𝗢𝗠 𝗟𝗢𝗩𝗘 𝗩𝗜𝗗𝗘𝗢 💖\n\n➤ Enjoy the romantic moment 🌸",
            attachment: fs.createReadStream(filePath)
          },
          event.threadID,
          () => fs.unlinkSync(filePath),
          event.messageID
        );
      });

      writer.on("error", () => {
        api.sendMessage("❌ | Video download error!", event.threadID, event.messageID);
      });

    } catch (error) {
      console.log(error);
      api.sendMessage("⚠️ | API error হয়েছে! পরে আবার try করো.", event.threadID, event.messageID);
    }
  }
};
